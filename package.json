{
  "name": "zen",
  "private": true,
  "scripts": {
    "web": "pnpm -F web dev",
    "api": "pnpm -F api dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check .",
    "check-types": "turbo run check-types",
    "clean": "pnpm run clean:dist && pnpm run clean:modules",
    "clean:dist": "pnpm -r --parallel exec rimraf -rf dist",
    "clean:modules": "pnpm -r --parallel exec rimraf -rf node_modules && rimraf -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5"
    }
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
