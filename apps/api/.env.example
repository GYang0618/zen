# ==================== 环境变量示例 ====================
# 复制此文件为 .env 并填入实际的值
# 不同环境请复制为 .env.development, .env.test, .env.production

# ==================== 应用配置 ====================
## 运行环境：开发/生产/测试
NODE_ENV=development

## 应用名称
APP_NAME=Admin

## 应用监听端口
PORT=3000

## API 全局前缀
API_PREFIX=/api

# ==================== 数据库配置 ====================
## 数据库连接字符串（PostgreSQL/MySQL/MongoDB 等）
DATABASE_URL=postgresql://admin:admin123@localhost:5432/admin_dev?schema=public

# ==================== JWT 认证配置 ====================
## JWT 签名密钥（生产环境必须 ≥ 32 字符）
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long

## JWT 过期时间
JWT_EXPIRES_IN=15m

## JWT 刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 日志配置 ====================
## 日志级别
LOG_LEVEL=debug

# ==================== CORS 配置 ====================
## 允许的跨域源（多个用逗号分隔）
CORS_ORIGIN=*

# ==================== 限流配置 ====================
## 限流窗口期（毫秒）
THROTTLE_TTL=60000

## 限流请求数
THROTTLE_LIMIT=10

# ==================== Swagger 配置 ====================
## 是否启用 Swagger
SWAGGER_ENABLED=true

## Swagger 访问路径
SWAGGER_PATH=docs


# ==================== AI 配置 ====================
# OpenAI配置
OPENAI_BASE_URL='your url'
OPENAI_API_KEY='sk-*******'

# Langsmith配置
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY='your api key'
LANGSMITH_PROJECT="study"
