# ==================== 测试环境配置 ====================

# 运行环境
NODE_ENV="test"

# 应用监听端口
PORT=3001

# ==================== 数据库配置 ====================
# 测试环境数据库（独立的测试数据库，便于隔离）
DATABASE_URL="postgresql://user:password@localhost:5432/dbname_test?schema=public"

# ==================== JWT 认证配置 ====================
# 测试环境 JWT 密钥
JWT_SECRET="test-jwt-secret-key-that-is-long-enough-for-testing-purpose"

# ==================== 日志配置 ====================
# 测试环境使用 info 级别，避免过多调试输出
LOG_LEVEL="info"

# ==================== CORS 配置 ====================
# 测试环境限制 CORS
CORS_ORIGIN="http://localhost:3001"

# ==================== Swagger 配置 ====================
# 测试环境禁用 Swagger
SWAGGER_ENABLED=false
